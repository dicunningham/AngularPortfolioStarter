rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This allows public read access for all files
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // This restricts write (upload/delete/update) access to only authenticated users
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}